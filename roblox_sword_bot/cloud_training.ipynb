   "source": [
    "# Roblox Sword Bot - Cloud GPU Training\n",
    "\n",
    "This notebook is designed to run on **Kaggle** or **Google Colab** to train the Behavior Cloning (BC) model using a free cloud GPU.\n",
    "\n",
    "### Instructions for Kaggle:\n",
    "1. In the right sidebar, click **Session Options** -> **Accelerator** -> **GPU T4 x2**.\n",
    "2. Upload your `data.zip` (containing your `data/recordings` folder) by clicking **Add Data** -> **Upload**.\n",
    "3. Run the cells below."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!git clone https://github.com/Iampancrea/Machine-learning.git\n",
    "%cd Machine-learning/roblox_sword_bot"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install dependencies (ignoring local Windows ones like pywin32)\n",
    "!pip install torch torchvision torchaudio numpy opencv-python pyyaml"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import shutil\n",
    "\n",
    "# Kaggle mounts uploaded data in /kaggle/input/\n",
    "# We need to copy it into our working directory's data folder\n",
    "DATA_SOURCE = \"/kaggle/input/your-dataset-name/recordings\"  # Change this if your dataset name is different\n",
    "DATA_DEST = \"./data/recordings\"\n",
    "\n",
    "os.makedirs(DATA_DEST, exist_ok=True)\n",
    "\n",
    "if os.path.exists(DATA_SOURCE):\n",
    "    print(\"Copying dataset...\")\n",
    "    for f in os.listdir(DATA_SOURCE):\n",
    "        if f.endswith('.npz'):\n",
    "            shutil.copy(os.path.join(DATA_SOURCE, f), os.path.join(DATA_DEST, f))\n",
    "    print(f\"Copied {len(os.listdir(DATA_DEST))} recording files.\")\n",
    "else:\n",
    "    print(f\"WARNING: Could not find data at {DATA_SOURCE}. Please check your Kaggle input directory.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Start Behavior Cloning training using the cloud GPU\n",
    "!python main.py train_bc"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from IPython.display import FileLink\n",
    "import os\n",
    "\n",
    "checkpoint_path = \"./checkpoints/best_model.pth\"\n",
    "if os.path.exists(checkpoint_path):\n",
    "    print(\"Training complete! Download your model below:\")\n",
    "    display(FileLink(checkpoint_path))\n",
    "else:\n",
    "    print(\"No checkpoint found. Did the training complete successfully?\")"
   ]
  }
